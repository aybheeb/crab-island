# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# URL of the standalone print server.
# Local dev:   http://localhost:3001
# Production:  https://your-subdomain.yourdomain.com  (from Cloudflare Tunnel — run `cloudflared tunnel info crab-island-print` to find it)
PRINT_SERVER_URL=http://localhost:3001

# Shared secret between this app and the print server.
# Use any long random string — must match PRINT_API_KEY on the print server.
PRINT_API_KEY=change-me-to-a-random-string

# Exact Windows printer name(s) the print server sends jobs to (print-server only, not read by the Next.js app).
# Comma-separated — the server tries each in order until one succeeds. Optional; falls back to the
# hardcoded defaults in server/services/printService.js if unset. Find exact names via `Get-Printer` in PowerShell.
KITCHEN_PRINTER_NAMES=Star TSP650II Cutter
CASHIER_PRINTER_NAMES=EPSON TM-T20 Receipt,EPSON TM-T20
