# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# URL of the standalone print server.
# Local dev:   http://localhost:3001
# Production:  https://your-static-domain.ngrok-free.app  (from ngrok dashboard)
PRINT_SERVER_URL=http://localhost:3001

# Shared secret between this app and the print server.
# Use any long random string — must match PRINT_API_KEY on the print server.
PRINT_API_KEY=change-me-to-a-random-string
